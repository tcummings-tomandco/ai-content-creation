# Tom & Co AI Content Engine — local environment variables
#
# Copy this file to `.env` (same directory) and fill in the values.
# The `.env` file is gitignored and never committed.
#
# For the cloud-scheduled Claude Routine, these same variables are
# set in the Routine's environment settings rather than read from
# this file.

# Storyblok — used by scripts/push_to_storyblok.py to create blog
# post drafts in the Tom & Co space.
#
# Get OAUTH_TOKEN from Storyblok → My Account → Personal access tokens.
# Get SPACE_ID from the URL of the Tom & Co space.
# Get ACCESS_TOKEN from Space → Settings → Access Tokens (preview token).
STORYBLOK_OAUTH_TOKEN=
STORYBLOK_SPACE_ID=
STORYBLOK_ACCESS_TOKEN=

# Storyblok region. Tom & Co space is on EU. Leave as-is.
STORYBLOK_REGION=eu

# GitHub — used by the routine to commit engine-state updates
# (output/, roadmap.json status, stat_bank.json) back to the
# ai-content-creation repo. Not used to push the article itself.
# Personal access token with `repo` scope on tcummings-tomandco/ai-content-creation.
GITHUB_TOKEN=
